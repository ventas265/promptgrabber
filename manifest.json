{
  "manifest_version": 3,
  "name": "PromptGrabber",
  "version": "1.0",
  "description": "Copia prompts de imágenes IA con hover en Pinterest, Instagram, X y más",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}